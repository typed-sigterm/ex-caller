{
  "type": "module",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "build": "bun run build:web && bun run build:app",
    "build:app": "tauri build",
    "build:web": "vite build",
    "deploy": "bun run build:web && bunx wrangler pages deploy dist",
    "deploy:preview": "bun run build:web && bunx wrangler pages deploy dist --branch preview",
    "dev": "tauri dev",
    "dev:web": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "type-check:app": "vue-tsc --noEmit -p tsconfig.app.json",
    "type-check:bun": "vue-tsc --noEmit -p tsconfig.bun.json",
    "type-check:test": "vue-tsc --noEmit -p tsconfig.test.json",
    "type-check": "bun run --config=bunfig.vue-tsc.toml type-check:app && bun run --config=bunfig.vue-tsc.toml type-check:bun && bun run --config=bunfig.vue-tsc.toml type-check:test"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@aws-crypto/sha256-browser": "^5.2.0",
    "@iconify-json/ant-design": "^1.2.5",
    "@iconify-json/ep": "^1.2.4",
    "@iconify-json/lucide": "^1.2.109",
    "@iconify-json/vscode-icons": "^1.2.50",
    "@intlify/unplugin-vue-i18n": "^11.2.3",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tsconfig/bun": "^1.0.10",
    "@typed-sigterm/eslint-config": "^1.7.1",
    "@types/bun": "^1.3.14",
    "@types/markdown-it": "^14.1.2",
    "@types/semver": "^7.7.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/tsconfig": "^0.9.1",
    "@vueuse/core": "^14.3.0",
    "driver.js": "^1.4.0",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "js-confetti": "^0.13.1",
    "markdown-it-for-inline": "^2.0.1",
    "mitt": "^3.0.1",
    "mixpanel-browser": "^2.79.0",
    "mock-local-storage": "^1.1.24",
    "naive-ui": "^2.44.1",
    "npm-run-all2": "^9.0.0",
    "pinia": "^3.0.4",
    "semver": "^7.8.0",
    "unocss": "^66.7.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-markdown": "^30.0.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.4",
    "vue-tsc": "^3.3.1",
    "wrangler": "^4.93.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "core-js",
    "esbuild",
    "sharp",
    "vue-demi",
    "workerd"
  ]
}
